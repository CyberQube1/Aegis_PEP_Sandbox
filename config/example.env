# Public Aegis paper sandbox PEP configuration template.
# Copy values into a private local environment file if needed. Do not commit
# real credentials, certificates, keys, endpoint hostnames, mesh IDs, binding
# IDs, or tenant identifiers.

AEGIS_SANDBOX_MODEL=stub_model
AEGIS_SANDBOX_OUTPUT_DIR=outputs
AEGIS_SANDBOX_ALLOW_REAL_MODEL_CALLS=false

# Controlled Aegis PDP mode. Values are provided out-of-band by SPQR for
# reviewer/research validation. The public package does not include a local
# mock PDP or Aegis decision simulator.
AEGIS_PDP_BASE_URL=<provided-by-spqr>
AEGIS_PDP_DECISION_PATH=/v1/mesh/decision
AEGIS_TENANT_ID=<provided-by-spqr>
AEGIS_ORG_ID=<provided-by-spqr>
AEGIS_MESH_CONNECTION_ID=<provided-by-spqr>
AEGIS_MESH_BINDING_ID=<provided-by-spqr>
AEGIS_CLIENT_CA_FILE=<local-private-path>
AEGIS_CLIENT_CERT_FILE=<local-private-path>
AEGIS_CLIENT_KEY_FILE=<local-private-path>

# Optional local model adapters. Leave unset for offline public smoke tests.
AEGIS_SANDBOX_FRONTIER_A_PROVIDER=
AEGIS_SANDBOX_FRONTIER_A_MODEL=
AEGIS_SANDBOX_FRONTIER_A_BASE_URL=
AEGIS_SANDBOX_FRONTIER_A_API_KEY=
